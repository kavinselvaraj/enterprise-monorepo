    "extends": "@repo/typescript-config/base.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": ".",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "types": [
            "vitest/globals"
        ]
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}